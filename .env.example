APP_NAME=Criclytics AI
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1|\\[::1\\]|\\[::\\])(?::\\d+)?$

CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=180
CACHE_TTL_MIN_SECONDS=30
CACHE_TTL_MAX_SECONDS=240
CACHE_NAMESPACE=analysis-v3

RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_SUBNET_MULTIPLIER=4
REQUEST_TIMEOUT_SECONDS=15
MAX_REQUEST_BODY_BYTES=4096
TREND_WINDOW_SIZE=5
TREND_TTL_SECONDS=900

TEXT_ENGINE_MODEL=signal-synthesizer-v1
TEXT_ENGINE_SEED=7

TOTAL_OVERS_DEFAULT=20
PROMPT_VERSION=insight-v2
